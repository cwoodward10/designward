---
import type { HTMLAttributes } from 'astro/types';
import ClientA from './utility/ClientA.svelte';

interface props extends HTMLAttributes<"a"> {
    href: string | null | undefined
};
const { href, ...rest }: props = Astro.props as props;
---

<ClientA client:load href={href} title={rest.title} customClasses={rest.class}>
    <slot></slot>
</Client>