---
const { title } = Astro.props;
---

<head>
    <script is:inline>
        // prevents flicker if we check this in the head
        const NO_MOTION_KEY = 'reduce-motion';
        const MODE_KEY = 'mode';

        let motionVal = localStorage.getItem(NO_MOTION_KEY);
        if (motionVal == null) {
            motionVal = window.matchMedia("(prefers-reduced-motion)").matches ? 'true' : 'false';
        }
        if (motionVal != null) {
            const reduceMotion = motionVal === 'true';
            document.querySelector('html')?.classList.toggle(NO_MOTION_KEY, reduceMotion);
        }

        let modeVal = localStorage.getItem(MODE_KEY);
        if (modeVal == null) {
            modeVal = window.matchMedia("(prefers-color-scheme: dark)").matches ? 'dark' : 'light';
        }
        if (modeVal != null) {
            const lightMode = modeVal === 'light';
            const modeClass = lightMode ? 'light' : 'dark'
            document.querySelector('html')?.classList.toggle(modeClass, lightMode);
        }
    </script>
    <meta charset="UTF-8" />
    <meta name="description" content="DesignWard is Chris Woodward's portfolio Website and digital garden. Discussing web engineering and design." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400..600;1,100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sofia+Sans:ital,wght@0,400..500;1,1..1000&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat+Alternates:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Handlee&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href="https://www.designward.io" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="DesignWard" href={new URL("rss.xml", Astro.site)} />
    <title>{title}</title>
</head>